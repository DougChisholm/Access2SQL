<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>@ViewData["Title"] – SchoolTests</title>
  <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
  <header class="nav-header">
    <a class="nav-brand" asp-page="/Index">
      <svg viewBox="0 0 16 16" aria-hidden="true">
        <path d="M10.5 0a5.499 5.499 0 1 1 0 11 5.499 5.499 0 0 1 0-11zM8 6v4.5h1V6H8zm0-2v1h1V4H8zM2 13.5A1.5 1.5 0 0 1 3.5 12h9a1.5 1.5 0 0 1 0 3h-9A1.5 1.5 0 0 1 2 13.5z"/>
      </svg>
      SchoolTests
    </a>
    <ul class="nav-links">
      <li><a asp-page="/Tests/Index">Tests</a></li>
      <li><a asp-page="/Students/Index">Students</a></li>
      <li><a asp-page="/Tests/Manage">Manage Tests</a></li>
    </ul>
  </header>

  <main>
    @RenderBody()
  </main>

  <script>
    // Highlight active nav link
    (function () {
      var path = window.location.pathname.toLowerCase();
      document.querySelectorAll('.nav-links a').forEach(function (a) {
        var href = a.getAttribute('href') || '';
        if (href && path.startsWith(href.toLowerCase()) && href !== '/') {
          a.classList.add('active');
        }
      });
    })();
  </script>
  @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
