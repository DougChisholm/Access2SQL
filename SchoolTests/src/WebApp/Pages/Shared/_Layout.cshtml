<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — School Tests</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

<!-- ── Navigation Header ───────────────────────────────── -->
<header class="site-header">
    <div class="site-header-inner">
        <a class="site-logo" asp-page="/Index">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <rect x="2" y="3" width="16" height="14" rx="2" stroke="white" stroke-width="1.5"/>
                <path d="M6 7h8M6 10h8M6 13h5" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            School Tests
        </a>

        <nav class="site-nav" aria-label="Main navigation">
            <a asp-page="/ChooseTest"
               class="@(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/ChooseTest") == true ? "active" : "")">
                📋 Enter Results
            </a>
            <a asp-page="/Students/Index"
               class="@(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Students") == true ? "active" : "")">
                🎓 Students
            </a>
            <a asp-page="/Tests/Index"
               class="@(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Tests") == true ? "active" : "")">
                📝 Tests
            </a>
        </nav>

        <div class="site-nav-right">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <span style="color:rgba(255,255,255,0.6);font-size:13px;">@User.Identity.Name</span>
                <form method="post" asp-page="/Account/Logout" style="display:inline;">
                    @Html.AntiForgeryToken()
                    <button type="submit">Sign out</button>
                </form>
            }
            else
            {
                <a asp-page="/Account/Login">Sign in</a>
            }
        </div>
    </div>
</header>

<!-- ── Page Content ────────────────────────────────────── -->
<main>
    @RenderBody()
</main>

<!-- ── Footer ──────────────────────────────────────────── -->
<footer class="site-footer">
    <span>School Test Results System &mdash; Migrated from Microsoft Access</span>
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
<script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)

</body>
</html>
