@page
@model SchoolTests.Web.Pages.Account.LogoutModel
@{
    ViewData["Title"] = "Signed Out";
}

<div class="page-wrapper" style="text-align:center;padding-top:80px;">
    <div style="font-size:48px;margin-bottom:16px;">👋</div>
    <h1 style="margin-bottom:8px;">You've been signed out</h1>
    <p class="text-muted">Thank you for using School Tests.</p>
    <div style="margin-top:24px;display:flex;gap:12px;justify-content:center;">
        <a asp-page="/Account/Login" class="btn btn-primary">Sign in again</a>
        <a asp-page="/Index" class="btn btn-secondary">Go to Dashboard</a>
    </div>
</div>
