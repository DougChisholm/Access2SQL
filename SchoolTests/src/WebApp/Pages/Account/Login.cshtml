@page
@model SchoolTests.Web.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Sign In";
    Layout = "_Layout";
}

<div class="auth-container">
    <div class="auth-logo">
        <div style="font-size:40px;margin-bottom:8px;">📚</div>
        <h1>School Tests</h1>
        <p class="text-muted" style="font-size:13px;margin-top:4px;">Sign in to your account</p>
    </div>

    <div class="auth-card">
        <div class="auth-hint">
            <strong>Default credentials:</strong><br/>
            Email: <code>admin@schooltests.local</code><br/>
            Password: <code>Admin123!</code>
        </div>

        <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

        <form method="post">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label asp-for="Input.Email" class="form-label">Email address</label>
                <input asp-for="Input.Email" class="form-control" type="email" autofocus
                       placeholder="admin@schooltests.local" autocomplete="email" />
                <span asp-validation-for="Input.Email" class="field-validation-error"></span>
            </div>
            <div class="form-group">
                <label asp-for="Input.Password" class="form-label">Password</label>
                <input asp-for="Input.Password" class="form-control" type="password"
                       placeholder="••••••••" autocomplete="current-password" />
                <span asp-validation-for="Input.Password" class="field-validation-error"></span>
            </div>
            <div class="form-group" style="display:flex;align-items:center;gap:8px;margin-bottom:20px;">
                <input asp-for="Input.RememberMe" type="checkbox" id="rememberMe"
                       style="accent-color:var(--c-accent);width:14px;height:14px;" />
                <label for="rememberMe" style="font-size:13px;margin:0;cursor:pointer;">Remember me</label>
            </div>
            <button type="submit" class="btn btn-primary w-100" style="justify-content:center;">
                Sign in
            </button>
        </form>
    </div>

    <p class="text-muted" style="text-align:center;margin-top:16px;font-size:12px;">
        Authentication is optional for general access.
        <a asp-page="/Index">Continue without signing in →</a>
    </p>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
