@page
@model SchoolTests.Web.Pages.Students.CreateModel
@{
    ViewData["Title"] = "Add Student";
}

<div class="page-wrapper">
    <div class="breadcrumb">
        <a asp-page="/Index">Home</a>
        <span class="breadcrumb-sep">›</span>
        <a asp-page="Index">Students</a>
        <span class="breadcrumb-sep">›</span>
        <span>Add Student</span>
    </div>

    <div class="page-header">
        <h1 class="page-title">➕ Add Student</h1>
    </div>

    <div class="card" style="max-width:480px;">
        <div class="card-header">
            <span class="card-title">Student Details</span>
        </div>
        <form method="post">
            <div class="card-body">
                <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>
                <div class="form-group">
                    <label asp-for="Student.StudentName" class="form-label">
                        Student Name <span class="required-indicator" style="color:var(--c-danger)">*</span>
                    </label>
                    <input asp-for="Student.StudentName" class="form-control" autofocus placeholder="e.g. Alice Johnson" />
                    <span asp-validation-for="Student.StudentName" class="field-validation-error"></span>
                </div>
            </div>
            <div class="card-footer">
                <button type="submit" class="btn btn-primary">Save Student</button>
                <a asp-page="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
