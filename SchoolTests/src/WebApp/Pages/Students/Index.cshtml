@page
@model WebApp.Pages.Students.IndexModel
@{
    ViewData["Title"] = "Students";
}

<div class="page-wrapper">
  <nav class="breadcrumb">
    <a asp-page="/Index">Home</a>
    <span class="sep">/</span>
    <span>Students</span>
  </nav>

  <div class="page-header">
    <div><h1>Students</h1><p>Manage the student list.</p></div>
  </div>

  @if (TempData["Success"] != null)
  {
    <div class="alert alert-success">@TempData["Success"]</div>
  }

  <div style="display:grid; grid-template-columns: 1fr 1fr; gap:24px; align-items:start;" class="students-grid">

    <!-- Add / Edit Form -->
    <div class="card">
      <div class="card-header">
        <h2>@(Model.EditId.HasValue ? "Edit Student" : "Add New Student")</h2>
      </div>
      <div class="card-body">
        <form method="post" asp-page-handler="Save">
          <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>
          @if (Model.EditId.HasValue)
          {
            <input type="hidden" name="EditId" value="@Model.EditId" />
          }
          <div class="form-group">
            <label class="form-label" asp-for="NewName">Student Name</label>
            <input class="form-control" asp-for="NewName" placeholder="e.g. Jane Doe" />
            <span asp-validation-for="NewName" class="field-validation-error"></span>
          </div>
          <div style="display:flex; gap:8px; flex-wrap:wrap;">
            <button type="submit" class="btn btn-primary">
              @(Model.EditId.HasValue ? "Save Changes" : "Add Student")
            </button>
            @if (Model.EditId.HasValue)
            {
              <a asp-page="/Students/Index" class="btn btn-secondary">Cancel</a>
            }
          </div>
        </form>
      </div>
    </div>

    <!-- Student List -->
    <div class="card">
      <div class="card-header">
        <h2>All Students</h2>
        <span class="badge badge-blue">@Model.Students.Count</span>
      </div>
      @if (!Model.Students.Any())
      {
        <div class="empty-state"><div class="empty-icon">🎓</div><h3>No students yet</h3></div>
      }
      else
      {
        <table class="data-table">
          <thead>
            <tr>
              <th>Name</th>
              <th style="width:130px; text-align:right;">Actions</th>
            </tr>
          </thead>
          <tbody>
            @foreach (var s in Model.Students)
            {
              <tr>
                <td>@s.StudentName</td>
                <td style="text-align:right; white-space:nowrap;">
                  <a asp-page="/Students/Index" asp-route-editId="@s.StudentId" class="btn btn-secondary btn-sm">Edit</a>
                  <form method="post" asp-page-handler="Delete" style="display:inline;">
                    <input type="hidden" name="deleteId" value="@s.StudentId" />
                    <button type="submit" class="btn btn-danger btn-sm"
                      onclick="return confirm('Delete this student? All their results will also be deleted.')">Delete</button>
                  </form>
                </td>
              </tr>
            }
          </tbody>
        </table>
      }
    </div>
  </div>
</div>

<style>
  @@media (max-width: 680px) {
    .students-grid { grid-template-columns: 1fr !important; }
  }
</style>
