@page
@model WebApp.Pages.Results.EnterModel
@{
    ViewData["Title"] = $"Results – {Model.TestDescription}";
}

<div class="page-wrapper">
  <nav class="breadcrumb">
    <a asp-page="/Index">Home</a>
    <span class="sep">/</span>
    <a asp-page="/Tests/Index">Tests</a>
    <span class="sep">/</span>
    <span>@Model.TestDescription</span>
  </nav>

  <div class="page-header">
    <div>
      <h1>@Model.TestDescription</h1>
      <p>Enter or update marks for each student. Leave blank if not yet marked.</p>
    </div>
    <div style="display:flex; gap:8px; align-items:center; flex-wrap:wrap;">
      <span class="badge badge-green">@Model.MarkedCount / @Model.Rows.Count marked</span>
      <a asp-page="/Tests/Index" class="btn btn-secondary">← Back to Tests</a>
    </div>
  </div>

  @if (TempData["Success"] != null)
  {
    <div class="alert alert-success">@TempData["Success"]</div>
  }

  @if (!Model.Rows.Any())
  {
    <div class="card">
      <div class="empty-state">
        <div class="empty-icon">🎓</div>
        <h3>No students found</h3>
        <p>Add students before entering results.</p>
        <a asp-page="/Students/Index" class="btn btn-primary" style="margin-top:16px;">Manage Students</a>
      </div>
    </div>
  }
  else
  {
    <form method="post">
      <input type="hidden" name="TestId" value="@Model.TestId" />
      <div class="card">
        <div class="card-header">
          <h2>Student Results</h2>
          <button type="submit" class="btn btn-primary">💾 Save All Marks</button>
        </div>
        <table class="data-table">
          <thead>
            <tr>
              <th>#</th>
              <th>Student Name</th>
              <th style="text-align:center;">Mark (0–100)</th>
              <th style="text-align:center;">Status</th>
            </tr>
          </thead>
          <tbody>
            @for (int i = 0; i < Model.Rows.Count; i++)
            {
              var row = Model.Rows[i];
              <tr>
                <td style="color:var(--color-muted); font-size:12px;">@(i + 1)</td>
                <td><strong>@row.StudentName</strong></td>
                <td style="text-align:center;">
                  <input type="hidden" name="Rows[@i].ResultId" value="@row.ResultId" />
                  <input type="hidden" name="Rows[@i].StudentId" value="@row.StudentId" />
                  <input type="hidden" name="Rows[@i].StudentName" value="@row.StudentName" />
                  <input
                    class="form-control mark-input"
                    type="number"
                    name="Rows[@i].Mark"
                    value="@row.Mark"
                    min="0" max="100"
                    placeholder="—"
                    autocomplete="off"
                    @(i == 0 ? "autofocus" : "") />
                </td>
                <td style="text-align:center;">
                  @if (row.Mark.HasValue)
                  {
                    <span class="badge badge-green">✓ @row.Mark</span>
                  }
                  else
                  {
                    <span class="badge badge-gray">Pending</span>
                  }
                </td>
              </tr>
            }
          </tbody>
        </table>
        <div style="padding:16px 20px; border-top:1px solid var(--color-border); display:flex; justify-content:flex-end;">
          <button type="submit" class="btn btn-primary">💾 Save All Marks</button>
        </div>
      </div>
    </form>
  }
</div>
