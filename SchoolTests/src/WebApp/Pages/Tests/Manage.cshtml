@page
@model WebApp.Pages.Tests.ManageModel
@{
    ViewData["Title"] = "Manage Tests";
}

<div class="page-wrapper">
  <nav class="breadcrumb">
    <a asp-page="/Index">Home</a>
    <span class="sep">/</span>
    <a asp-page="/Tests/Index">Tests</a>
    <span class="sep">/</span>
    <span>Manage</span>
  </nav>

  <div class="page-header">
    <div><h1>Manage Tests</h1><p>Add, edit, or delete tests.</p></div>
  </div>

  @if (TempData["Success"] != null)
  {
    <div class="alert alert-success">@TempData["Success"]</div>
  }

  <div style="display:grid; grid-template-columns: 1fr 1fr; gap:24px; align-items:start;" class="manage-grid">

    <!-- Add / Edit Form -->
    <div class="card">
      <div class="card-header">
        <h2>@(Model.EditId.HasValue ? "Edit Test" : "Add New Test")</h2>
      </div>
      <div class="card-body">
        <form method="post" asp-page-handler="Save">
          <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>
          @if (Model.EditId.HasValue)
          {
            <input type="hidden" name="EditId" value="@Model.EditId" />
          }
          <div class="form-group">
            <label class="form-label" asp-for="NewDescription">Test Description</label>
            <input class="form-control" asp-for="NewDescription" placeholder="e.g. Mathematics Term 1" />
            <span asp-validation-for="NewDescription" class="field-validation-error"></span>
          </div>
          <div style="display:flex; gap:8px; flex-wrap:wrap;">
            <button type="submit" class="btn btn-primary">
              @(Model.EditId.HasValue ? "Save Changes" : "Add Test")
            </button>
            @if (Model.EditId.HasValue)
            {
              <a asp-page="/Tests/Manage" class="btn btn-secondary">Cancel</a>
            }
          </div>
        </form>
      </div>
    </div>

    <!-- Test List -->
    <div class="card">
      <div class="card-header">
        <h2>All Tests</h2>
        <span class="badge badge-blue">@Model.Tests.Count</span>
      </div>
      @if (!Model.Tests.Any())
      {
        <div class="empty-state"><div class="empty-icon">🗂️</div><h3>No tests yet</h3></div>
      }
      else
      {
        <table class="data-table">
          <thead>
            <tr>
              <th>Description</th>
              <th style="width:120px; text-align:right;">Actions</th>
            </tr>
          </thead>
          <tbody>
            @foreach (var test in Model.Tests)
            {
              <tr>
                <td>@test.TestDescription</td>
                <td style="text-align:right; white-space:nowrap;">
                  <a asp-page="/Tests/Manage" asp-route-editId="@test.TestId" class="btn btn-secondary btn-sm">Edit</a>
                  <form method="post" asp-page-handler="Delete" style="display:inline;">
                    <input type="hidden" name="deleteId" value="@test.TestId" />
                    <button type="submit" class="btn btn-danger btn-sm"
                      onclick="return confirm('Delete this test? All results will also be deleted.')">Delete</button>
                  </form>
                </td>
              </tr>
            }
          </tbody>
        </table>
      }
    </div>
  </div>
</div>

<style>
  @@media (max-width: 680px) {
    .manage-grid { grid-template-columns: 1fr !important; }
  }
</style>
