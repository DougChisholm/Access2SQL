@page "{id:int}"
@model SchoolTests.Web.Pages.Tests.EditModel
@{
    ViewData["Title"] = "Edit Test";
}

<div class="page-wrapper">
    <div class="breadcrumb">
        <a asp-page="/Index">Home</a>
        <span class="breadcrumb-sep">›</span>
        <a asp-page="Index">Tests</a>
        <span class="breadcrumb-sep">›</span>
        <span>Edit Test</span>
    </div>

    <div class="page-header">
        <h1 class="page-title">✏️ Edit Test</h1>
    </div>

    <div class="card" style="max-width:560px;">
        <div class="card-header">
            <span class="card-title">Update Test Details</span>
        </div>
        <form method="post">
            <div class="card-body">
                <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>
                <input type="hidden" asp-for="Test.TestId" />
                <div class="form-group">
                    <label asp-for="Test.TestDescription" class="form-label">
                        Test Description <span style="color:var(--c-danger)">*</span>
                    </label>
                    <input asp-for="Test.TestDescription" class="form-control" autofocus />
                    <span asp-validation-for="Test.TestDescription" class="field-validation-error"></span>
                </div>
            </div>
            <div class="card-footer">
                <button type="submit" class="btn btn-primary">Save Changes</button>
                <a asp-page="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
