@page
@model WebApp.Pages.Tests.IndexModel
@{
    ViewData["Title"] = "Choose Test";
}

<div class="page-wrapper">
  <nav class="breadcrumb">
    <a asp-page="/Index">Home</a>
    <span class="sep">/</span>
    <span>Tests</span>
  </nav>

  <div class="page-header">
    <div>
      <h1>Choose a Test</h1>
      <p>Select a test below to enter or update student results.</p>
    </div>
  </div>

  <div class="card">
    <div class="card-header">
      <h2>Available Tests</h2>
      <span class="badge badge-blue">@Model.Tests.Count test(s)</span>
    </div>

    @if (!Model.Tests.Any())
    {
      <div class="empty-state">
        <div class="empty-icon">🗂️</div>
        <h3>No tests yet</h3>
        <p>Create some tests first before entering results.</p>
        <a asp-page="/Tests/Manage" class="btn btn-primary" style="margin-top:16px;">Manage Tests</a>
      </div>
    }
    else
    {
      <ul class="test-list">
        @foreach (var test in Model.Tests)
        {
          <li class="test-list-item">
            <div>
              <div class="test-name">@test.TestDescription</div>
              <div class="test-meta">
                @test.MarkedCount of @test.TotalStudents students marked
              </div>
            </div>
            <a asp-page="/Results/Enter" asp-route-testId="@test.TestId" class="btn btn-primary">
              Enter Results →
            </a>
          </li>
        }
      </ul>
    }
  </div>

  <div style="margin-top:16px; display:flex; gap:10px; flex-wrap:wrap;">
    <a asp-page="/Tests/Manage" class="btn btn-secondary">+ Add / Manage Tests</a>
    <a asp-page="/Students/Index" class="btn btn-secondary">Manage Students</a>
  </div>
</div>
