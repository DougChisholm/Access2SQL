@page "{id:int}"
@model SchoolTests.Web.Pages.Tests.DeleteModel
@{
    ViewData["Title"] = "Delete Test";
}

<div class="page-wrapper">
    <div class="breadcrumb">
        <a asp-page="/Index">Home</a>
        <span class="breadcrumb-sep">›</span>
        <a asp-page="Index">Tests</a>
        <span class="breadcrumb-sep">›</span>
        <span>Delete Test</span>
    </div>

    <div class="page-header">
        <h1 class="page-title">🗑️ Delete Test</h1>
    </div>

    <div class="card" style="max-width:520px;">
        <div class="card-header">
            <span class="card-title">Confirm Deletion</span>
        </div>
        <div class="card-body">
            <div class="alert alert-danger">
                ⚠️ This action cannot be undone. All student results for this test will also be deleted.
            </div>
            <p><strong>Test:</strong> @Model.Test.TestDescription</p>
            <p><strong>Results recorded:</strong> @Model.ResultCount</p>
        </div>
        <div class="card-footer">
            <form method="post">
                <button type="submit" class="btn btn-danger">🗑️ Yes, Delete</button>
            </form>
            <a asp-page="Index" class="btn btn-secondary">Cancel</a>
        </div>
    </div>
</div>
