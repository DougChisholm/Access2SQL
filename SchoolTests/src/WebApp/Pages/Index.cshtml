@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
}

<div class="page-wrapper">
  <div class="hero">
    <h1>📚 SchoolTests</h1>
    <p>Manage school tests and student results with ease. Select a test, enter marks, and track progress.</p>
    <a asp-page="/Tests/Index" class="btn btn-primary" style="font-size:15px; padding: 10px 28px;">
      Start Entering Results →
    </a>
  </div>

  <div class="feature-grid">
    <a asp-page="/Tests/Index" class="feature-card">
      <span class="feature-icon">📝</span>
      <h3>Enter Test Results</h3>
      <p>Choose a test and enter or update marks for all students in a fast, grid-based view.</p>
    </a>
    <a asp-page="/Students/Index" class="feature-card">
      <span class="feature-icon">🎓</span>
      <h3>Manage Students</h3>
      <p>Add, edit, or remove students from the system. Keep the student list up to date.</p>
    </a>
    <a asp-page="/Tests/Manage" class="feature-card">
      <span class="feature-icon">🗂️</span>
      <h3>Manage Tests</h3>
      <p>Create and manage tests. Define what assessments are available for students.</p>
    </a>
  </div>

  <div class="stat-row" style="margin-top:40px; justify-content:center;">
    <div class="stat-chip">
      <div class="stat-value">@Model.StudentCount</div>
      <div class="stat-label">Students</div>
    </div>
    <div class="stat-chip">
      <div class="stat-value">@Model.TestCount</div>
      <div class="stat-label">Tests</div>
    </div>
    <div class="stat-chip">
      <div class="stat-value">@Model.MarkedCount</div>
      <div class="stat-label">Marks Recorded</div>
    </div>
  </div>
</div>
