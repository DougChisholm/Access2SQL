@page
@model IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="page-wrapper">
    <div class="page-header">
        <div>
            <h1 class="page-title">📚 School Test Results</h1>
            <p class="page-subtitle">Manage student test marks and track academic progress</p>
        </div>
        <a asp-page="/ChooseTest" class="btn btn-primary btn-lg">
            📋 Enter Results
        </a>
    </div>

    <!-- Stats -->
    <div class="stats-grid">
        <a asp-page="/Students/Index" class="stat-card">
            <div class="stat-number">@Model.StudentCount</div>
            <div class="stat-label">🎓 Students</div>
        </a>
        <a asp-page="/Tests/Index" class="stat-card">
            <div class="stat-number">@Model.TestCount</div>
            <div class="stat-label">📝 Tests</div>
        </a>
        <div class="stat-card">
            <div class="stat-number">@Model.ResultCount</div>
            <div class="stat-label">✅ Results Recorded</div>
        </div>
        <div class="stat-card">
            <div class="stat-number">@(Model.AverageMark.HasValue ? $"{Model.AverageMark:F0}" : "—")</div>
            <div class="stat-label">📊 Average Mark</div>
        </div>
    </div>

    <!-- Two-column layout -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-bottom:24px;">

        <!-- Recent Tests -->
        <div class="card">
            <div class="card-header">
                <span class="card-title">Recent Tests</span>
                <a asp-page="/Tests/Index" class="btn btn-sm btn-secondary">View all</a>
            </div>
            @if (Model.RecentTests.Any())
            {
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Test</th>
                            <th>Results</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in Model.RecentTests)
                        {
                            <tr>
                                <td>@t.TestDescription</td>
                                <td><span class="badge badge-blue">@t.StudentResults.Count</span></td>
                                <td>
                                    <a asp-page="/EnterResults" asp-route-testId="@t.TestId"
                                       class="btn btn-sm btn-primary">Enter Marks</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="empty-state">
                    <div class="empty-state-icon">📝</div>
                    <p class="empty-state-title">No tests yet</p>
                    <a asp-page="/Tests/Create" class="btn btn-primary btn-sm">Add a test</a>
                </div>
            }
        </div>

        <!-- Quick Actions -->
        <div class="card">
            <div class="card-header">
                <span class="card-title">Quick Actions</span>
            </div>
            <div class="card-body" style="display:flex;flex-direction:column;gap:12px;">
                <a asp-page="/ChooseTest" class="btn btn-primary" style="justify-content:center;">
                    📋 Enter Test Results
                </a>
                <a asp-page="/Students/Create" class="btn btn-secondary" style="justify-content:center;">
                    ➕ Add Student
                </a>
                <a asp-page="/Tests/Create" class="btn btn-secondary" style="justify-content:center;">
                    ➕ Add Test
                </a>
                <a asp-page="/Students/Index" class="btn btn-secondary" style="justify-content:center;">
                    🎓 Manage Students
                </a>
            </div>
        </div>
    </div>

    <!-- Top Performers -->
    @if (Model.TopPerformers.Any())
    {
        <div class="card">
            <div class="card-header">
                <span class="card-title">Top Performers (Average Mark)</span>
            </div>
            <table class="data-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Student</th>
                        <th>Tests Taken</th>
                        <th>Average Mark</th>
                    </tr>
                </thead>
                <tbody>
                    @{ int rank = 1; }
                    @foreach (var p in Model.TopPerformers)
                    {
                        <tr>
                            <td><span class="badge badge-grey">@rank</span></td>
                            <td>@p.StudentName</td>
                            <td>@p.TestsTaken</td>
                            <td>
                                @{
                                    var markClass = p.AvgMark >= 75 ? "mark-high" : p.AvgMark >= 50 ? "mark-mid" : "mark-low";
                                }
                                <span class="mark-badge @markClass">@($"{p.AvgMark:F1}")</span>
                            </td>
                        </tr>
                        rank++;
                    }
                </tbody>
            </table>
        </div>
    }
</div>
