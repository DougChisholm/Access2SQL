@page
@model ErrorModel
@{
    ViewData["Title"] = "Error";
}

<div class="page-wrapper" style="text-align:center;padding-top:80px;">
    <div style="font-size:48px;margin-bottom:16px;">⚠️</div>
    <h1>Something went wrong</h1>
    <p class="text-muted">An error occurred while processing your request.</p>
    @if (Model.RequestId != null)
    {
        <p class="text-muted" style="font-size:12px;">Request ID: <code>@Model.RequestId</code></p>
    }
    <div style="margin-top:24px;">
        <a asp-page="/Index" class="btn btn-primary">← Back to Dashboard</a>
    </div>
</div>
