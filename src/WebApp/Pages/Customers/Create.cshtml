@page
@model WebApp.Pages.Customers.CreateModel
@{
    ViewData["Title"] = "Nowy klient";
}

<h1>Nowy klient</h1>
<a asp-page="Index" class="btn btn-secondary mb-3">Powrót</a>

<form method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="mb-3">
        <label class="form-label">Imię</label>
        <input asp-for="Klient.Imie" class="form-control" />
        <span asp-validation-for="Klient.Imie" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label class="form-label">Nazwisko</label>
        <input asp-for="Klient.Nazwisko" class="form-control" />
        <span asp-validation-for="Klient.Nazwisko" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label class="form-label">Data urodzenia</label>
        <input asp-for="Klient.DataUrodzenia" type="date" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Płeć</label>
        <select asp-for="Klient.Plec" class="form-select">
            <option value="M">M - Mężczyzna</option>
            <option value="K">K - Kobieta</option>
        </select>
    </div>
    <div class="mb-3">
        <label class="form-label">PESEL</label>
        <input asp-for="Klient.Pesel" class="form-control" />
    </div>
    <button type="submit" class="btn btn-success">Zapisz</button>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
