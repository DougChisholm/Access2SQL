@page
@model WebApp.Pages.Customers.IndexModel
@{
    ViewData["Title"] = "Klienci";
}

<h1>Klienci</h1>
<a asp-page="Create" class="btn btn-success mb-3">Dodaj klienta</a>

<form method="get" class="mb-3 d-flex gap-2">
    <input type="text" name="search" value="@Model.Search" class="form-control" placeholder="Szukaj po imieniu lub nazwisku..." />
    <button type="submit" class="btn btn-primary">Szukaj</button>
    <a asp-page="Index" class="btn btn-secondary">Wyczyść</a>
</form>

<table class="table table-striped">
    <thead>
        <tr>
            <th>ID</th><th>Imię</th><th>Nazwisko</th><th>Data urodzenia</th><th>Płeć</th><th>PESEL</th><th>Akcje</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var k in Model.Klienci)
        {
            <tr>
                <td>@k.IdKlienta</td>
                <td>@k.Imie</td>
                <td>@k.Nazwisko</td>
                <td>@k.DataUrodzenia.ToString("dd.MM.yyyy")</td>
                <td>@k.Plec</td>
                <td>@k.Pesel</td>
                <td>
                    <a asp-page="Details" asp-route-id="@k.IdKlienta" class="btn btn-sm btn-info">Szczegóły</a>
                    <a asp-page="Edit" asp-route-id="@k.IdKlienta" class="btn btn-sm btn-warning">Edytuj</a>
                    <a asp-page="Delete" asp-route-id="@k.IdKlienta" class="btn btn-sm btn-danger">Usuń</a>
                </td>
            </tr>
        }
    </tbody>
</table>
