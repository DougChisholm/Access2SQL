@page
@model WebApp.Pages.Reports.CustomersByGenderModel
@{
    ViewData["Title"] = "Klienci wg płci";
}

<h1>Klienci wg płci</h1>
<a asp-page="Index" class="btn btn-secondary mb-3">Powrót</a>

<table class="table table-bordered" style="max-width:400px">
    <thead><tr><th>Płeć</th><th>Liczba</th></tr></thead>
    <tbody>
        @foreach (var item in Model.Data)
        {
            <tr>
                <td>@(item.Plec == "M" ? "Mężczyzna" : "Kobieta")</td>
                <td>@item.Count</td>
            </tr>
        }
    </tbody>
</table>
