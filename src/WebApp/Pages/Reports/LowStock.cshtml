@page
@model WebApp.Pages.Reports.LowStockModel
@{
    ViewData["Title"] = "Niski stan magazynowy";
}

<h1>Produkty z niskim stanem magazynowym (poniżej 5)</h1>
<a asp-page="Index" class="btn btn-secondary mb-3">Powrót</a>

<table class="table table-striped">
    <thead><tr><th>Produkt</th><th>Stan</th></tr></thead>
    <tbody>
        @foreach (var item in Model.Data)
        {
            <tr class="@(item.Ilosc == 0 ? "table-danger" : "table-warning")">
                <td>@item.Nazwa</td>
                <td>@item.Ilosc</td>
            </tr>
        }
    </tbody>
</table>
