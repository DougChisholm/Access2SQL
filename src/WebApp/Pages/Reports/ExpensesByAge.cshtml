@page
@model WebApp.Pages.Reports.ExpensesByAgeModel
@{
    ViewData["Title"] = "Wydatki wg grupy wiekowej";
}

<h1>Wydatki wg grupy wiekowej</h1>
<a asp-page="Index" class="btn btn-secondary mb-3">Powrót</a>

<table class="table table-bordered" style="max-width:400px">
    <thead><tr><th>Grupa wiekowa</th><th>Łączne wydatki</th></tr></thead>
    <tbody>
        @foreach (var item in Model.Data)
        {
            <tr>
                <td>@item.AgeGroup</td>
                <td>@item.TotalSpend.ToString("C")</td>
            </tr>
        }
    </tbody>
</table>
