@page
@model WebApp.Pages.IndexModel
@{
    ViewData["Title"] = "Strona główna";
}

<div class="text-center">
    <h1 class="display-4">Polski sklep internetowy</h1>
    <p>System zarządzania sklepem</p>
</div>

<div class="row mt-4">
    <div class="col-md-4 mb-3">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Klienci</h5>
                <p class="card-text">Zarządzaj klientami, adresami i koszykami.</p>
                <a asp-page="/Customers/Index" class="btn btn-primary">Przejdź</a>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Produkty</h5>
                <p class="card-text">Zarządzaj produktami i kategoriami.</p>
                <a asp-page="/Products/Index" class="btn btn-primary">Przejdź</a>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Magazyn</h5>
                <p class="card-text">Stany magazynowe produktów.</p>
                <a asp-page="/Warehouse/Index" class="btn btn-primary">Przejdź</a>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Narzędzia</h5>
                <p class="card-text">Kalkulator walut PLN/EUR.</p>
                <a asp-page="/Tools/Index" class="btn btn-secondary">Przejdź</a>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Obniżka cen</h5>
                <p class="card-text">Zastosuj rabat na wybrany produkt.</p>
                <a asp-page="/PriceReduction/Index" class="btn btn-warning">Przejdź</a>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Generator danych</h5>
                <p class="card-text">Generuj losowych klientów z zamówieniami.</p>
                <a asp-page="/Generator/Index" class="btn btn-info">Przejdź</a>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Raporty</h5>
                <p class="card-text">Statystyki i raporty sprzedaży.</p>
                <a asp-page="/Reports/Index" class="btn btn-success">Przejdź</a>
            </div>
        </div>
    </div>
</div>
