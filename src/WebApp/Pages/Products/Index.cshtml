@page
@model WebApp.Pages.Products.IndexModel
@{
    ViewData["Title"] = "Produkty";
}

<h1>Produkty</h1>
<a asp-page="Create" class="btn btn-success mb-3">Dodaj produkt</a>

<table class="table table-striped">
    <thead>
        <tr><th>ID</th><th>Nazwa</th><th>Cena</th><th>Gwarancja (mies.)</th><th>Dostępny</th><th>Akcje</th></tr>
    </thead>
    <tbody>
        @foreach (var p in Model.Produkty)
        {
            <tr>
                <td>@p.IdProduktu</td>
                <td>@p.Nazwa</td>
                <td>@p.Cena.ToString("C")</td>
                <td>@p.Gwarancja</td>
                <td>@(p.Dostepny ? "Tak" : "Nie")</td>
                <td>
                    <a asp-page="Edit" asp-route-id="@p.IdProduktu" class="btn btn-sm btn-warning">Edytuj</a>
                    <a asp-page="Delete" asp-route-id="@p.IdProduktu" class="btn btn-sm btn-danger">Usuń</a>
                </td>
            </tr>
        }
    </tbody>
</table>
