@page "{id:int}"
@model WebApp.Pages.Products.DeleteModel
@{
    ViewData["Title"] = "Usuń produkt";
}

<h1>Usuń produkt</h1>
<div class="alert alert-danger">
    <p>Czy na pewno chcesz usunąć produkt <strong>@Model.Produkt.Nazwa</strong>?</p>
</div>
<form method="post">
    <button type="submit" class="btn btn-danger">Tak, usuń</button>
    <a asp-page="Index" class="btn btn-secondary">Anuluj</a>
</form>
