@page "{id:int}"
@model WebApp.Pages.Products.EditModel
@{
    ViewData["Title"] = "Edytuj produkt";
}

<h1>Edytuj produkt</h1>
<a asp-page="Index" class="btn btn-secondary mb-3">Powrót</a>

<form method="post">
    <input type="hidden" asp-for="Produkt.IdProduktu" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="mb-3">
        <label class="form-label">Nazwa</label>
        <input asp-for="Produkt.Nazwa" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Opis</label>
        <textarea asp-for="Produkt.Opis" class="form-control" rows="3"></textarea>
    </div>
    <div class="mb-3">
        <label class="form-label">Cena</label>
        <input asp-for="Produkt.Cena" type="number" step="0.01" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Gwarancja (miesiące)</label>
        <input asp-for="Produkt.Gwarancja" type="number" class="form-control" />
    </div>
    <div class="mb-3 form-check">
        <input asp-for="Produkt.Dostepny" class="form-check-input" type="checkbox" />
        <label class="form-check-label">Dostępny</label>
    </div>
    <button type="submit" class="btn btn-warning">Zapisz zmiany</button>
</form>

<hr />
<h3>Kategorie</h3>
<ul class="list-group mb-3">
    @foreach (var pk in Model.ProduktKategorie)
    {
        <li class="list-group-item d-flex justify-content-between align-items-center">
            @pk.Kategoria?.Nazwa
            <form method="post" asp-page-handler="RemoveCategory" style="display:inline">
                <input type="hidden" name="kategoriaId" value="@pk.IdKategorii" />
                <button type="submit" class="btn btn-sm btn-danger">Usuń</button>
            </form>
        </li>
    }
</ul>

<form method="post" asp-page-handler="AddCategory" class="d-flex gap-2">
    <select name="kategoriaId" class="form-select">
        @foreach (var k in Model.AllKategorie)
        {
            <option value="@k.IdKategorii">@k.Nazwa</option>
        }
    </select>
    <button type="submit" class="btn btn-success">Dodaj kategorię</button>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
