@page
@model WebApp.Pages.Tools.IndexModel
@{
    ViewData["Title"] = "Kalkulator walut";
}

<h1>Kalkulator walut PLN / EUR</h1>

<div class="row">
    <div class="col-md-6">
        <form method="post" asp-page-handler="PlnToEur">
            <h4>PLN → EUR</h4>
            <div class="mb-3">
                <label class="form-label">Kwota w PLN</label>
                <input type="number" step="0.01" name="amount" class="form-control" value="@Model.AmountPln" />
            </div>
            <button type="submit" class="btn btn-primary">Przelicz</button>
            @if (Model.ResultEur.HasValue)
            {
                <div class="alert alert-success mt-3">
                    @Model.AmountPln PLN = <strong>@Model.ResultEur.Value.ToString("F2") EUR</strong>
                </div>
            }
        </form>
    </div>
    <div class="col-md-6">
        <form method="post" asp-page-handler="EurToPln">
            <h4>EUR → PLN</h4>
            <div class="mb-3">
                <label class="form-label">Kwota w EUR</label>
                <input type="number" step="0.01" name="amount" class="form-control" value="@Model.AmountEur" />
            </div>
            <button type="submit" class="btn btn-primary">Przelicz</button>
            @if (Model.ResultPln.HasValue)
            {
                <div class="alert alert-success mt-3">
                    @Model.AmountEur EUR = <strong>@Model.ResultPln.Value.ToString("F2") PLN</strong>
                </div>
            }
        </form>
    </div>
</div>
<small class="text-muted">Kurs: 1 EUR = 4.48 PLN</small>
