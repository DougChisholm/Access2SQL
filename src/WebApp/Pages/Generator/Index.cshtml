@page
@model WebApp.Pages.Generator.IndexModel
@{
    ViewData["Title"] = "Generator danych";
}

<h1>Generator klientów</h1>

@if (TempData["Result"] != null)
{
    <div class="alert alert-success">@TempData["Result"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<form method="post">
    <div class="mb-3">
        <label class="form-label">Liczba klientów do wygenerowania (max 10000)</label>
        <input asp-for="Count" type="number" min="1" max="10000" class="form-control" style="max-width:200px" />
        <span asp-validation-for="Count" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-info">Generuj</button>
</form>
<p class="text-muted mt-2">Generator tworzy losowych klientów z adresami i zamówieniami.</p>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
