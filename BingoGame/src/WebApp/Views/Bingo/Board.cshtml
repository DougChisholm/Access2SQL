@model List<WebApp.Domain.BingoRow>
@{
    ViewData["Title"] = "Bingo Board";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var calledNumbers = (List<int>)(ViewBag.CalledNumbers ?? new List<int>());
    int? lastNumber = TempData["LastNumber"] as int?;
    string? message = TempData["Message"] as string;
    string? messageType = TempData["MessageType"] as string ?? "info";
    int totalCalled = calledNumbers.Count;
    int remaining = 100 - totalCalled;

    // Column header labels: Col1=1, Col2=2, …, Col9=9, Col10=0 (tens)
    var colLabels = new[] { "1", "2", "3", "4", "5", "6", "7", "8", "9", "0" };
}

<div class="board-layout">

    <!-- ── LEFT PANEL: Board ─────────────────────────────────── -->
    <div class="board-panel">

        <!-- Status bar -->
        <div class="status-bar">
            <div class="status-item">
                <span class="status-label">Called</span>
                <span class="status-value called-count">@totalCalled</span>
            </div>
            <div class="status-item">
                <span class="status-label">Remaining</span>
                <span class="status-value remaining-count">@remaining</span>
            </div>
            @if (lastNumber.HasValue)
            {
                <div class="status-item highlight-item">
                    <span class="status-label">Last Number</span>
                    <span class="status-value last-number">@lastNumber</span>
                </div>
            }
        </div>

        @if (!string.IsNullOrEmpty(message))
        {
            <div class="alert alert-@messageType">@message</div>
        }

        <!-- Bingo grid -->
        <div class="board-wrapper">
            <table class="bingo-table" aria-label="Bingo board">
                <thead>
                    <tr>
                        <th class="row-header">Row</th>
                        @for (int c = 0; c < 10; c++)
                        {
                            <th class="col-header">@colLabels[c]</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Model)
                    {
                        int rowStart = (row.Id - 1) * 10 + 1;
                        int rowEnd = row.Id == 10 ? 100 : row.Id * 10;
                        var values = row.GetValues();

                        <tr>
                            <td class="row-header">@rowStart–@rowEnd</td>
                            @for (int c = 0; c < 10; c++)
                            {
                                // Original number: row determines tens, col determines ones
                                // col index 0-8 → ones 1-9, col index 9 → ones 0 (multiples of 10)
                                int onesDigit = c < 9 ? (c + 1) : 0;
                                int originalNumber = onesDigit == 0
                                    ? row.Id * 10
                                    : (row.Id - 1) * 10 + onesDigit;

                                bool isCalled = values[c] == 0;
                                bool isLast = lastNumber.HasValue && lastNumber.Value == originalNumber;
                                string cellClass = isCalled ? "cell called" : "cell";
                                if (isLast) cellClass += " cell-last";

                                <td class="@cellClass" title="@originalNumber">
                                    <span class="cell-number">@originalNumber</span>
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Action buttons -->
        <div class="board-actions">
            <form asp-controller="Bingo" asp-action="GetNumber" method="post" class="inline-form">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-primary btn-lg"
                        @(remaining == 0 ? "disabled" : "")>
                    🎲 Get Number
                </button>
            </form>

            <form asp-controller="Bingo" asp-action="NewGame" method="post" class="inline-form">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-secondary btn-lg"
                        onclick="return confirm('Start a new game? The current board will be reset.')">
                    🔄 New Game
                </button>
            </form>

            <form asp-controller="Bingo" asp-action="Finish" method="post" class="inline-form">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline btn-lg">
                    🏠 Finish
                </button>
            </form>
        </div>
    </div>

    <!-- ── RIGHT PANEL: Called numbers list ──────────────────── -->
    <div class="called-panel">
        <h2 class="called-title">
            Called Numbers
            <span class="badge">@totalCalled</span>
        </h2>

        @if (calledNumbers.Count == 0)
        {
            <p class="called-empty">No numbers called yet. Press <strong>Get Number</strong> to begin!</p>
        }
        else
        {
            <ol class="called-list">
                @foreach (var num in calledNumbers)
                {
                    <li class="called-item @(num == lastNumber ? "called-item-last" : "")">
                        <span class="called-number">@num</span>
                    </li>
                }
            </ol>
        }
    </div>

</div>
