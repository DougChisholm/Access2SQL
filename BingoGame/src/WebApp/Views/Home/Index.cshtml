@{
    ViewData["Title"] = "Home";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="hero-container">
    <div class="hero-card">
        <div class="hero-icon">🎱</div>
        <h1 class="hero-title">Bingo Caller</h1>
        <p class="hero-subtitle">
            Numbers 1–100 &bull; 10&times;10 grid &bull; Classic Bingo fun
        </p>

        <div class="hero-actions">
            <form asp-controller="Bingo" asp-action="NewGame" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-primary btn-lg">
                    🎮 New Game
                </button>
            </form>
        </div>

        <p class="hero-hint">
            Press <strong>New Game</strong> to reset the board and start calling numbers.
        </p>
    </div>
</div>
